{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "OrganizationReadOnlyAccess",
      "Effect": "Allow",
      "Principal": "*",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:BatchGetImage",
        "ecr:DescribeImageScanFindings",
        "ecr:DescribeImages",
        "ecr:DescribeRepositories",
        "ecr:GetAuthorizationToken",
        "ecr:GetDownloadUrlForLayer",
        "ecr:GetLifecyclePolicy",
        "ecr:GetLifecyclePolicyPreview",
        "ecr:GetRepositoryPolicy",
        "ecr:ListImages",
        "ecr:ListTagsForResource"
      ],
      "Condition": {
        "StringEquals": {
          "aws:PrincipalOrgID": [
            "o-56v5gp5fcu",
            "o-5l05z2urto"
          ]
        }
      }
    },
    {
      "Sid": "ProdImageRetagAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": [
          "arn:aws:iam::533267185808:role/argo_root_core_platform_infra_prod_eks",
          "arn:aws:iam::471112759938:role/argo_root_core_platform_infra_dev_eks"
        ]
      },
      "Action": [
        "ecr:PutImage"
      ]
    }
  ]
}